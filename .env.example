# vision-infra operator config — copy to .env and rotate before prod use.
#
# Required by docker compose. The base compose reads these from the host
# shell or a sibling .env file at compose/.env.

# -- Image tags ---------------------------------------------------------------
# Override with registry-tagged images for prod. Defaults match the local
# `docker build -t vision:dev` / `videonizer:dev` produced by each app repo.
VISION_IMAGE=vision:dev
VIDEONIZER_IMAGE=videonizer:dev

# -- Database (postgres) ------------------------------------------------------
POSTGRES_USER=videonizer
POSTGRES_PASSWORD=videonizer
POSTGRES_DB=videonizer

# -- Object store (minio) -----------------------------------------------------
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_BUCKET=videonizer

# -- Videonizer app -----------------------------------------------------------
# DATABASE_URL must reference the `postgres` service hostname inside the
# compose network (not localhost) — credentials must match POSTGRES_* above.
DATABASE_URL=postgresql+asyncpg://videonizer:videonizer@postgres:5432/videonizer
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_SECURE=false
MINIO_REGION=us-east-1

ALLOWED_ORIGINS=http://localhost,https://localhost
LOG_LEVEL=INFO

# -- Edge nginx ---------------------------------------------------------------
# Ports the edge nginx binds on the host. Override if 80/443 are taken.
EDGE_HTTP_PORT=80
EDGE_HTTPS_PORT=443
