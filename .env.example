# vision-infra 운영자 설정 — 통합 스택의 단일 소스 (single source of truth).
#
# 이 파일을 .env 로 복사한 뒤 운영 환경에 맞게 채우세요. 운영(prod)
# 배포 전 반드시 비밀번호와 도메인을 교체하세요.
#
#   cp .env.example .env
#   chmod 600 .env
#
# 사용법 (레포 루트에서):
#   # 개발 (sibling 저장소에서 빌드 — 루트 .env 자동 로드)
#   docker compose -f docker-compose.yml -f docker-compose.dev.yml up -d --build
#   # 운영 (레지스트리에서 pull, /appdata/* 바인드 마운트)
#   docker compose --env-file /appdata/app/vision-infra/.env \
#     -f docker-compose.yml -f docker-compose.prod.yml up -d
#
# 빈 .env 로 부팅:
#   REGISTRY_URL / IMAGE_PREFIX 만 채우면 나머지는 합리적 기본값으로 부팅됩니다.
#   compose 의 ${VAR:-default} 가 누락 변수를 메우고, ALLOWED_ORIGINS 미설정
#   시에는 videonizer 코드 기본값 "*" 가 적용되어 외부망에서도 동작합니다.
#
# 통합 운영 시 sub-repo 의 .env 는 사용되지 않습니다 — 이 파일이 유일한 소스.

# ============================================================================
# 1. 컨테이너 레지스트리 (필수)
# ============================================================================
# 모든 이미지가 ${REGISTRY_URL}/${IMAGE_PREFIX}/<name>:<tag> 경로에서
# 옵니다. 외부 Docker Hub / 공개 레지스트리는 사용하지 않습니다 (에어갑 정책).
# 사내 미러에 upstream 이미지를 IMAGE_PREFIX 아래로 push 해 두세요
# (예: docker.io/minio/minio → ${REGISTRY_URL}/${IMAGE_PREFIX}/minio).
REGISTRY_URL=harbor.example.com
IMAGE_PREFIX=paikku

# 운영자 호스트의 docker login 자격. CI 는 GitHub secrets 의 같은 이름을
# 읽어옵니다 (vision-infra/.github/workflows/reusable-build-push.yml).
REGISTRY_USERNAME=
REGISTRY_PASSWORD=

# 이미지 태그 핀 (릴리스에 맞춰 고정).
VISION_TAG=dev
VIDEONIZER_TAG=dev
POSTGRES_TAG=16-alpine
MINIO_TAG=latest
NGINX_TAG=1.27-alpine
PYTHON_TAG=3.12-slim
NODE_TAG=21-alpine
FFMPEG_TAG=7.1-ubuntu

# ============================================================================
# 2. 인프라 자격 증명 (postgres / minio root)
# ============================================================================
# 운영 배포 전 반드시 교체. dev 기본값(videonizer / minioadmin)은 약합니다.

# -- PostgreSQL --------------------------------------------------------------
POSTGRES_USER=videonizer
POSTGRES_PASSWORD=videonizer
POSTGRES_DB=videonizer

# -- MinIO -------------------------------------------------------------------
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_BUCKET=videonizer

# ============================================================================
# 3. videonizer 애플리케이션
# ============================================================================
# DATABASE_URL 의 호스트는 compose 서비스명 (`postgres`) 이어야 함 — 자격
# 증명은 위 POSTGRES_* 와 일치시켜야 합니다.
DATABASE_URL=postgresql+asyncpg://videonizer:videonizer@postgres:5432/videonizer
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_SECURE=false
MINIO_REGION=us-east-1

# CORS 허용 origin. 통합 스택은 엣지 nginx 가 same-origin 으로 라우팅하므로
# 사실상 불필요하지만, 다른 도메인의 vision 클라이언트가 직접 붙는 경우
# (도메인 분리 운영, 또는 dev override 가 노출한 :8000 으로 브라우저가 직접
# 호출) 를 위해 명시. 기본값은 dev override 의 호스트 origin (localhost) —
# 외부망/임의 origin 허용은 줄을 지우거나 "*" 로 교체 (코드 기본값이 "*").
ALLOWED_ORIGINS=http://localhost,https://localhost

LOG_LEVEL=INFO
# MAX_CONCURRENT_JOBS / SEGMENT_MAX_CONCURRENT 미설정 시 prod override 의
# 기본값(각각 6, 2) 사용.
#MAX_CONCURRENT_JOBS=
#SEGMENT_MAX_CONCURRENT=

# ============================================================================
# 4. vision 애플리케이션 (런타임 env — 재빌드 불필요)
# ============================================================================
# 이전엔 NEXT_PUBLIC_* 이라 마들어진 JS 번들에 인라인되는 빌드 타임 값이었으나,
# 이제는 루트 layout 이 매 요청마다 process.env 를 읽어 window.__ENV 로 주입합니다.
# 값을 바꿔도 이미지 재빌드 필요 없이 컴테이너 재시작만으로 적용.
#
# 통합 스택의 두 가지 운영 모드:
#
#   A) 엣지 nginx same-origin 라우팅 (운영 권장)
#      → 아래 3줄을 모두 비우거나 줄을 지우세요. vision SPA 가 상대경로
#        (/v1/segment 등) 로 호출 → nginx 가 videonizer 로 프록시.
#        도메인 1개로 운영하므로 CORS 도 신경 쓸 필요 없음.
#
#   B) dev override 가 :8000 을 호스트로 노출 → 브라우저가 직접 호출
#      → 아래 기본값(localhost:8000) 그대로. cp .env.example .env 후
#        compose dev 모드로 띄우면 vision SPA 가 localhost:8000 으로
#        직접 호출 (videonizer ALLOWED_ORIGINS 가 허용).
#
# 도메인 분리 운영(api.example.com 등) 이라면 절대 URL 로 교체.
VIDEONIZER_URL=http://localhost:8000
IMAGE_SEGMENT_ENDPOINT=http://localhost:8000/v1/segment
VIDEO_NORMALIZE_ENDPOINT=http://localhost:8000/v1/normalize?async_job=true

# ============================================================================
# 5. 엣지 nginx 포트
# ============================================================================
# 호스트의 80/443 이 사용 중이면 변경.
EDGE_HTTP_PORT=80
EDGE_HTTPS_PORT=443

# ============================================================================
# 6. 빌드 시 패키지 미러 / 프록시 (선택, 폐쇄망 전용)
# ============================================================================
# 비워두거나 줄 자체를 지우면 공용 npm / PyPI 를 그대로 사용합니다 —
# 외부망 빌드(공용 인터넷 CI 러너 포함)는 별도 설정이 필요 없습니다.
#
# 사내 Samsung Nexus 같은 폐쇄망 미러를 써야 한다면 해당 줄의 주석을
# 해제하세요. compose 가 .env 를 읽어 vision / videonizer 의 build args
# 로 흘려줍니다.

# vision (npm) — Dockerfile deps 스테이지가 .npmrc 에 기록.
#NPM_REGISTRY=http://nexus.adpaas.cloud.samsungds.net/repository/npm-dwp-group/
#NPM_PROXY=http://nexus.adpaas.cloud.samsungds.net/
#NPM_HTTPS_PROXY=http://nexus.adpaas.cloud.samsungds.net/
#NPM_STRICT_SSL=false

# videonizer (pip) — runtime 스테이지의 pip install 플래그.
#PIP_INDEX_URL=http://nexus.adpaas.cloud.samsungds.net/repository/dataservice-pypi/simple
#PIP_EXTRA_INDEX_URL=http://nexus.adpaas.cloud.samsungds.net/repository/itp-pypi-remote/simple
#PIP_TRUSTED_HOST=nexus.adpaas.cloud.samsungds.net
