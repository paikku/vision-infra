# vision-infra operator config — copy to .env and rotate before prod use.
#
# Required by docker compose. The base compose reads these from the host
# shell or a sibling .env file at compose/.env.

# -- Private container registry (Harbor / mirror) ----------------------------
# All images — base images (postgres, minio, nginx, python) and project
# images (vision, videonizer) — are pulled from a single path:
#   ${REGISTRY_URL}/${IMAGE_PREFIX}/<name>:<tag>
#
# REGISTRY_URL and IMAGE_PREFIX are REQUIRED. Empty values produce invalid
# image refs and `docker compose pull` will fail. Mirror upstream images
# under IMAGE_PREFIX with the simple name (e.g. push docker.io/minio/minio
# as ${REGISTRY_URL}/${IMAGE_PREFIX}/minio).
REGISTRY_URL=harbor.example.com
IMAGE_PREFIX=paikku

# Used by the operator host's `docker login` so `docker compose pull` can
# authenticate. The CI workflow (vision-infra/.github/workflows/
# reusable-build-push.yml) reads the same names from GitHub `secrets`.
REGISTRY_USERNAME=
REGISTRY_PASSWORD=

# -- Image tags ---------------------------------------------------------------
# Pin specific tags per release. Defaults match the names produced by the
# app repos' build pipelines (sha-prefixed tags written by
# reusable-build-push.yml) and the public upstream tags for base images.
VISION_TAG=dev
VIDEONIZER_TAG=dev
POSTGRES_TAG=16-alpine
MINIO_TAG=latest
NGINX_TAG=1.27-alpine
PYTHON_TAG=3.12-slim

# -- Database (postgres) ------------------------------------------------------
POSTGRES_USER=videonizer
POSTGRES_PASSWORD=videonizer
POSTGRES_DB=videonizer

# -- Object store (minio) -----------------------------------------------------
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_BUCKET=videonizer

# -- Videonizer app -----------------------------------------------------------
# DATABASE_URL must reference the `postgres` service hostname inside the
# compose network (not localhost) — credentials must match POSTGRES_* above.
DATABASE_URL=postgresql+asyncpg://videonizer:videonizer@postgres:5432/videonizer
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_SECURE=false
MINIO_REGION=us-east-1

ALLOWED_ORIGINS=http://localhost,https://localhost
LOG_LEVEL=INFO

# -- Edge nginx ---------------------------------------------------------------
# Ports the edge nginx binds on the host. Override if 80/443 are taken.
EDGE_HTTP_PORT=80
EDGE_HTTPS_PORT=443
