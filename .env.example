# vision-infra operator config — copy to .env and rotate before prod use.
#
# Required by docker compose. The base compose reads these from the host
# shell or a sibling .env file at compose/.env.

# -- Private container registry (Harbor / mirror) ----------------------------
# Set when all images must be pulled from a private registry. CI uses these
# (REGISTRY_USERNAME / REGISTRY_PASSWORD as repo or org secrets) for
# `docker login` in reusable-build-push.yml; deploy.yml uses REGISTRY_URL
# and IMAGE_PREFIX (as repo or org `vars`) to compute image refs.
# Leave REGISTRY_URL empty to fall back to public upstreams (ghcr.io / dockerhub).
REGISTRY_URL=
REGISTRY_USERNAME=
REGISTRY_PASSWORD=
# Path under the registry where the project images live (e.g. "paikku" so the
# full ref is harbor.example.com/paikku/vision:tag).
IMAGE_PREFIX=paikku

# -- Image tags / overrides ---------------------------------------------------
# Each service image is overridable. Use these to point at registry-mirrored
# images. Examples for a Harbor mirror:
#   VISION_IMAGE=harbor.example.com/paikku/vision:1.2.3
#   VIDEONIZER_IMAGE=harbor.example.com/paikku/videonizer:1.2.3
#   POSTGRES_IMAGE=harbor.example.com/dockerhub/postgres:16-alpine
#   MINIO_IMAGE=harbor.example.com/dockerhub/minio/minio:latest
#   NGINX_IMAGE=harbor.example.com/dockerhub/nginx:1.27-alpine
#   PYTHON_IMAGE=harbor.example.com/dockerhub/python:3.12-slim
# Defaults below match the local `docker build -t vision:dev` /
# `videonizer:dev` produced by each app repo and public upstream tags.
VISION_IMAGE=vision:dev
VIDEONIZER_IMAGE=videonizer:dev
POSTGRES_IMAGE=postgres:16-alpine
MINIO_IMAGE=minio/minio:latest
NGINX_IMAGE=nginx:1.27-alpine
PYTHON_IMAGE=python:3.12-slim

# -- Database (postgres) ------------------------------------------------------
POSTGRES_USER=videonizer
POSTGRES_PASSWORD=videonizer
POSTGRES_DB=videonizer

# -- Object store (minio) -----------------------------------------------------
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_BUCKET=videonizer

# -- Videonizer app -----------------------------------------------------------
# DATABASE_URL must reference the `postgres` service hostname inside the
# compose network (not localhost) — credentials must match POSTGRES_* above.
DATABASE_URL=postgresql+asyncpg://videonizer:videonizer@postgres:5432/videonizer
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_SECURE=false
MINIO_REGION=us-east-1

ALLOWED_ORIGINS=http://localhost,https://localhost
LOG_LEVEL=INFO

# -- Edge nginx ---------------------------------------------------------------
# Ports the edge nginx binds on the host. Override if 80/443 are taken.
EDGE_HTTP_PORT=80
EDGE_HTTPS_PORT=443
